# Overrides opcionales (también podés usar config.json o `qvox config set`).
# Precedencia: env > config.json > defaults.

# QVOX_HOME=~/.qvox          # carpeta de datos/config/modelos
# QVOX_HOST=0.0.0.0          # exponer en red
# QVOX_PORT=5111
# QVOX_API_KEY=cambia-esto   # proteger la API
# QVOX_LOG=debug             # nivel de log
# HF_TOKEN=hf_xxx            # descargas rápidas de HuggingFace
