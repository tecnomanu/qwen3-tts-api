# Optional overrides (you can also use config.json or `qvox config set`).
# Precedence: env > config.json > defaults.

# QVOX_HOME=~/.qvox          # data/config/models folder
# QVOX_HOST=0.0.0.0          # expose on the network
# QVOX_PORT=5111
# QVOX_API_KEY=change-me     # protect the API
# QVOX_LOG=debug             # log level
# HF_TOKEN=hf_xxx            # fast HuggingFace downloads
